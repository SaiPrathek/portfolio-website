{
  "name": "sai-prathek-kotha-portfolio",
  "version": "1.0.0",
  "description": "Portfolio website for Sai Prathek Kotha - dual theme (F1 Racing / The Office)",
  "author": "Sai Prathek Kotha",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "npx serve .",
    "dev": "npx serve . -l 3000",
    "format": "npx prettier --write \"*.{html,json}\" \"blog/**/*.html\" \"blog/**/*.json\" \"css/**/*.css\" \"js/**/*.js\" \"scripts/**/*.js\"",
    "validate:blog": "node scripts/validate-blog.js",
    "generate:post": "node scripts/generate-post.js"
  },
  "keywords": [
    "portfolio",
    "personal-website",
    "f1-theme",
    "office-theme"
  ]
}
